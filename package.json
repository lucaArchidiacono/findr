{
  "name": "findr",
  "version": "0.1.1",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "findr": "src/index.tsx"
  },
  "scripts": {
    "dev": "env DEBUG=true bun run --watch src/index.tsx",
    "build": "bun build --compile src/index.tsx --outfile dist/findr",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.tsx --outfile dist/findr-darwin-arm64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.tsx --outfile dist/findr-linux-x64",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@tsconfig/bun": "^1.0.9",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.59",
    "@ai-sdk/perplexity": "^2.0.16",
    "@opentui/core": "0.1.30",
    "@opentui/react": "0.1.30",
    "ai": "^5.0.86",
    "react": "19.1.1",
    "zod": "^4.1.12"
  }
}
